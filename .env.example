# Copy to .env and fill in values before running locally or in CI.
# Never commit .env to version control.

# ── Security ─────────────────────────────────────────────────────────────────
# Must be set in production. Generate with: openssl rand -hex 32
JWT_SECRET=change-me-in-production
SERVICE_SECRET=change-me-in-production

# ── Tax Rate ─────────────────────────────────────────────────────────────────
# Decimal fraction applied to order subtotals (e.g. 0.10 = 10%)
TAX_RATE=0.10

# ── Database URLs (per service) ───────────────────────────────────────────────
# Used by docker-compose; override individually for local dev outside Docker.
GATEWAY_DATABASE_URL=postgresql://erp:erp_dev_password@localhost:5432/erp_gateway
SALES_DATABASE_URL=postgresql://erp:erp_dev_password@localhost:5432/erp_sales
INVENTORY_DATABASE_URL=postgresql://erp:erp_dev_password@localhost:5432/erp_inventory
ACCOUNTING_DATABASE_URL=postgresql://erp:erp_dev_password@localhost:5432/erp_accounting
HR_DATABASE_URL=postgresql://erp:erp_dev_password@localhost:5432/erp_hr
PROCUREMENT_DATABASE_URL=postgresql://erp:erp_dev_password@localhost:5432/erp_procurement
DELIVERY_DATABASE_URL=postgresql://erp:erp_dev_password@localhost:5432/erp_delivery
