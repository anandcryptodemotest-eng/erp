generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ChartOfAccount {
  id       String  @id @default(cuid())
  tenantId String
  code     String
  name     String
  type     String  // ASSET, LIABILITY, EQUITY, REVENUE, EXPENSE
  parentId String?
  isActive Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  parent   ChartOfAccount?  @relation("Hierarchy", fields: [parentId], references: [id])
  children ChartOfAccount[] @relation("Hierarchy")
  lines    JournalEntryLine[]

  @@unique([tenantId, code])
  @@index([tenantId])
}

model JournalEntry {
  id          String   @id @default(cuid())
  tenantId    String
  date        DateTime
  reference   String?
  description String?
  isPosted    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  lines JournalEntryLine[]

  @@index([tenantId])
}

model JournalEntryLine {
  id             String @id @default(cuid())
  journalEntryId String
  accountId      String
  debit          Float  @default(0)
  credit         Float  @default(0)
  description    String?

  entry   JournalEntry   @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  account ChartOfAccount @relation(fields: [accountId], references: [id])
}

model Invoice {
  id            String   @id @default(cuid())
  tenantId      String
  number        String
  type          String   // RECEIVABLE, PAYABLE
  entityId      String?  // Customer or Vendor ID (from other services)
  entityName    String?
  sourceRef     String?  // SalesOrder ID or PurchaseOrder ID
  date          DateTime
  dueDate       DateTime
  subtotal      Float
  tax           Float    @default(0)
  total         Float
  paidAmount    Float    @default(0)
  status        String   @default("DRAFT") // DRAFT, ISSUED, PAID, PARTIALLY_PAID, OVERDUE, CANCELLED
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  payments    Payment[]
  creditNotes CreditNote[]

  @@unique([tenantId, number])
  @@index([tenantId])
  @@index([entityId])
}

model Payment {
  id        String   @id @default(cuid())
  tenantId  String
  invoiceId String
  amount    Float
  method    String   // CASH, BANK_TRANSFER, CREDIT_CARD, CHECK, OTHER
  reference String?
  date      DateTime
  createdAt DateTime @default(now())

  invoice Invoice @relation(fields: [invoiceId], references: [id])

  @@index([tenantId])
}

model CreditNote {
  id         String    @id @default(cuid())
  tenantId   String
  number     String
  invoiceId  String?
  entityId   String?
  entityName String?
  sourceRef  String?   // SalesReturn ID
  date       DateTime
  amount     Float
  status     String    @default("ISSUED") // ISSUED, APPLIED, REFUNDED, CANCELLED
  notes      String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  invoice Invoice? @relation(fields: [invoiceId], references: [id])

  @@unique([tenantId, number])
  @@index([tenantId])
}

model DebitNote {
  id         String    @id @default(cuid())
  tenantId   String
  number     String
  entityId   String?
  entityName String?
  sourceRef  String?   // PurchaseReturn ID
  date       DateTime
  amount     Float
  status     String    @default("ISSUED") // ISSUED, APPLIED, REFUNDED, CANCELLED
  notes      String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@unique([tenantId, number])
  @@index([tenantId])
}

model TaxRate {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  code        String
  rate        Float
  description String?
  isDefault   Boolean  @default(false)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([tenantId, code])
  @@index([tenantId])
}
